<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when the OS's version is Android 12 (API 31) or higher -->
    <style name="LaunchTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Control the Android 12+ native splash screen behavior -->
        <item name="android:windowSplashScreenBackground">#2E4A3F</item>
        <!-- Set the animated icon to transparent to allow the Flutter animated splash screen to handle the logo animation seamlessly -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started. -->
    <style name="NormalTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
